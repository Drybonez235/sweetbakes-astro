---
import "../styles/global.css";

import Page from "../layouts/index.astro";
---
<Page
page_title="Sweet Bakes Chicago - Always Nut Free and Allergy Friendly"
  page_description="Sweet Bakes Chicago is a nut-free cottage bakery in Chicago. Order custom cakes and allergy-friendly baked goods with confidence. Safe & delicious!"
>

<body class="bg-cream text-gray-800 antialiased min-h-screen flex flex-col">

<!-- HERO -->
<section class="relative w-full h-[75vh] overflow-hidden">
  <img src="christmas_images/christmas-cookie-hero-banner.png" 
       alt="Decorated Christmas cookies" 
       class="object-cover w-full h-full">

  <!-- Overlay 
  <div class="absolute inset-0 bg-black/40 backdrop-blur-[1px]"></div>-->

  <!-- Text and CTA -->
  <div class="absolute inset-0 flex flex-col items-center justify-center text-center border-black ">
    <div class="bg-brand-light-cream rounded-2xl px-4 py-5">
    <h1 class="text-6xl md:text-8xl font-display text-white drop-shadow-lg">
      Christmas Cookies Made With Joy
    </h1>
    <p class="text-lg md:text-2xl text-accent-gold mt-4 mb-8">
      Fresh baked. Hand decorated. Holiday magic in every bite.
    </p>
    <a href="#decorated-cookies" 
       class="px-8 py-4 bg-xmas-red text-white rounded-full text-xl shadow-lg hover:bg-red-700 transition-transform transform hover:scale-105">
      Order Now
    </a>
    </div>
  </div>
</section>

<!-- Intro message -->
<section class="max-w-4xl mx-auto text-center py-16 px-4">
  <h2 class="text-4xl md:text-6xl font-extrabold text-xmas-green mb-6">
    ’Tis The Season For Cookies
  </h2>
  <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
    Celebrate the holidays with flavors that spark nostalgia and
    decorated cookies crafted to make spirits bright.
  </p>
</section>

<!-- Featured Christmas Cookies -->
<section id="decorated-cookies" class="container mx-auto px-6 py-16">
  <h2 class="text-center text-5xl font-extrabold text-xmas-red mb-10 tracking-tight">
    The Stars of the Season ✨
  </h2>

  <!-- Card Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Traditional Cookies Card -->
    <a href="traditional-cookies#traditional-cookies" class="bg-white rounded-3xl shadow-lg p-6 border border-gray-200 hover:scale-[1.03] transform transition">
      <img src="christmas_images/christmas-cookie-giant-chocolate-chip.avif"
           alt="Traditional cookies"
           class="rounded-2xl w-full h-64 object-cover mb-6">

      <h3 class="text-2xl font-bold text-xmas-red mb-3">Traditional Cookies</h3>
      <p class="text-gray-700 text-lg mb-4">
        All your favorite flavors plus our holiday classics!
      </p>
      <ul class="text-base text-gray-600 space-y-1 mb-4">
        <li>Mint Chip</li>
        <li>White Chocolate Peppermint</li>
        <li>Gingerbread Crinkle</li>
      </ul>

      <p class="font-chunky mt-4 text-xl font-medium text-gray-700">$27 per dozen</p>
    </a>

    <!-- Decorated Cookies Card (highlighted / center) -->
    <a href="decorated-cookies#custom_cookies" class=" bg-white rounded-3xl shadow-xl p-6 border border-gray-200  hover:scale-[1.03] transform transition">
      <img src="christmas_images/christmas-cookie-snowman.avif"
           alt="Decorated cookies"
           class="rounded-2xl w-full h-64 object-cover mb-6">

      <h3 class="text-3xl font-bold text-xmas-green mb-2">Decorated Cookies</h3>
      <p class="text-gray-700 text-lg mb-4">
        Custom designs and joyful shapes for every celebration.
      </p>

      <ul class="text-base text-gray-600 space-y-1">
        <li>Gingerbread</li>
        <li>Warm Cinnamon</li>
        <li>Pumpkin Spice</li>
      </ul>

      <p class="font-chunky  mt-4 text-xl font-medium text-gray-700">$32 per dozen</p>
      
    </a>

    <!-- Biscotti Card -->
    <a href="traditional-cookies#biscotti" class="bg-white rounded-3xl shadow-lg p-6 border border-gray-200 hover:scale-105 transform transition">
      <img src="christmas_images/christmas-biscotti-cranberry.avif"
           alt="Biscotti"
           class="rounded-2xl w-full h-64 object-cover mb-6">

      <h3 class="text-2xl font-bold text-accent-brown mb-3">Festive Biscotti</h3>
      <p class="text-gray-700 text-lg mb-4">
        Made to be enjoyed with your hot beverage of choice.
      </p>
      <ul class="text-base text-gray-600 space-y-1 mb-4">
        <li>Cranberry Orange</li>
        <li>Pumpkin Spice</li>
        <li>Chocolate Cardamom</li>
      </ul>
    </ul>

    <p class="font-chunky mt-4 text-xl font-medium text-gray-700">$27 per dozen</p>
    </a>
</section>
</Page>