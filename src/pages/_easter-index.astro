---
import "../styles/global.css";

import Page from "../layouts/index.astro";
---

<Page
page_title="Sweet Bakes Chicago - Always Nut Free and Allergy Friendly"
  page_description="Sweet Bakes Chicago is a nut-free cottage bakery in Chicago. Order custom cakes and allergy-friendly baked goods with confidence. Safe & delicious!"
>

 <main class="max-w-7xl mx-auto px-4 sm:px-6 py-12 space-y-24">
  
  <section class="w-full">
    <div class="w-full h-64 md:h-[450px] bg-gray-100 rounded-3xl overflow-hidden shadow-lg border border-brand-cream">
      <img src="easter-header.avif" alt="Hero - Sweet Bakes Chicago" class="w-full h-full object-cover" />
    </div>
  </section>

  <section class="text-center pt-10">
    <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
      Order Your <span class="text-brand-terracotta">Easter Treats</span> Today!
    </h1>
    <p class="text-xl md:text-2xl text-brand-brown font-body max-w-3xl mx-auto leading-relaxed">
      Celebrate spring with Sweet Bakes Chicago. From hand-decorated cookies to our signature infused cakes, we have everything you need for a sweet holiday.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-16">
    
    <div class="group flex flex-col">
      <div class="overflow-hidden rounded-3xl bg-white shadow-sm border border-brand-cream mb-6">
        <img src="easter-cupcakes.avif" alt="Easter Cupcakes" class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-105">
      </div>
      <div class="flex justify-between items-start px-2 mb-4">
        <div>
          <h2 class="text-4xl font-bold mb-1">Cupcakes</h2>
          <p class="text-brand-grey-green text-lg">Traditional & Signature flavors</p>
        </div>
        <div class="text-right">
          <p class="text-3xl font-bold text-brand-terracotta">$40<span class="text-lg text-brand-brown">/doz</span></p>
        </div>
      </div>
      <a href="/pricing#cupcakes" class="inline-block bg-brand-teal text-white text-center py-4 rounded-xl font-bold text-lg hover:bg-brand-dark-brown transition-colors">Order Cupcakes</a>
    </div>

    <div class="group flex flex-col">
      <div class="overflow-hidden rounded-3xl bg-white shadow-sm border border-brand-cream mb-6">
        <img src="easter-decorated-cookies.avif" alt="Easter Decorated Cookies" class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-105">
      </div>
      <div class="flex justify-between items-start px-2 mb-4">
        <div>
          <h2 class="text-4xl font-bold mb-1">Sugar Cookies</h2>
          <p class="text-brand-grey-green text-lg">Hand-decorated spring designs</p>
        </div>
        <div class="text-right">
          <p class="text-3xl font-bold text-brand-terracotta">$40<span class="text-lg text-brand-brown">/doz</span></p>
        </div>
      </div>
      <a href="decorated-cookies#custom-cookies" class="inline-block bg-brand-terracotta text-white text-center py-4 rounded-xl font-bold text-lg hover:bg-brand-dark-brown transition-colors">Order Cookies</a>
    </div>

    <div class="group flex flex-col">
      <div class="overflow-hidden rounded-3xl bg-white shadow-sm border border-brand-cream mb-6">
        <img src="easter-flower-cakepops.avif" alt="Easter Flower Cake Pops" class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-105">
      </div>
      <div class="flex justify-between items-start px-2 mb-4">
        <div>
          <h2 class="text-4xl font-bold mb-1">Cake Pop Flowers</h2>
          <p class="text-brand-grey-green text-lg">Beautiful edible bouquets</p>
        </div>
        <div class="text-right text-brand-terracotta font-bold">
          <p class="text-3xl font-bold text-brand-terracotta">$40<span class="text-lg text-brand-brown">/doz</span></p>
        </div>
      </div>
      <a href="pricing#cake-pops" class="inline-block bg-brand-brown text-white text-center py-4 rounded-xl font-bold text-lg hover:bg-brand-dark-brown transition-colors">Order a Bouquet</a>
    </div>

    <div class="group flex flex-col">
      <div class="overflow-hidden rounded-3xl bg-white shadow-sm border border-brand-cream mb-6">
        <img src="easter-cake-pucks.avif" alt="Easter Cake Pucks" class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-105">
      </div>
      <div class="flex justify-between items-start px-2 mb-4">
        <div>
          <h2 class="text-4xl font-bold mb-1">Cake Pucks</h2>
          <p class="text-brand-grey-green text-lg max-w-xs">Filled with cake, preserves, or frosting.</p>
        </div>
        <div class="text-right text-brand-terracotta font-bold">
          <p class="text-3xl">$40<span class="text-lg text-brand-brown">/doz</span></p>
        </div>
      </div>
      <a href="pricing#cake-pucks" class="inline-block bg-brand-teal text-white text-center py-4 rounded-xl font-bold text-lg hover:bg-brand-dark-brown transition-colors">Order Cake Pucks</a>
    </div>
  </section>

  <section class="py-12 bg-brand-light-cream rounded-[3rem] px-6 md:px-12 border border-brand-cream/50">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-bold mb-4">Signature Cake Flavors</h2>
      <p class="text-brand-brown text-xl italic tracking-wide">Specially created flavors for the cake connoisseur</p>
      <div class="w-24 h-1.5 bg-brand-teal mx-auto mt-6 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-teal shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Ube Dream</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          This boba tea inspired cake is made with real ube! It is an ube sponge filled with vanilla mousse and frosted in an ube and mascarpone buttercream. It’s naturally purple!
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-terracotta shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Honey Ginger</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Delicious honey cake infused with ginger. Filled with a Greek yogurt honey mousse and frosted in a whipped chocolate ganache. Bump it up with an extra splash of orange zest for an addition burst of flavor.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-brown shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Chocolate Chai</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Our delicious chocolate cake mixed with real black tea, cardamom, cinnamon, ginger, and black pepper. Filled and frosted in Chai tea Italian buttercream. Coated in a dark chocolate pour over ganache.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-teal shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Triple Berry Lemon</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          This 3 layer Signature Cake is made with light and fluffy lemon cake with whole blueberries. Filled with a layer of strawberry, and a layer of raspberry Italian buttercream. Frosted in lemon Italian buttercream and topped with fresh berries.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-terracotta shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Chocolate Chip Cookie Dough</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Brown sugar cake filled with egg-less chocolate chip cookie dough. Frosted with salted vanilla buttercream or chocolate ganache.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-brown shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">May I have S'more Cake</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Your choice of chocolate cake or graham cracker cake, layered with chocolate ganache. Frosted with our special marshmallow meringue and toasted to perfection. Topped with chocolate ganache drips and a real s'more.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-teal shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Blackberry Peach</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Yellow cake filled with a house made peach puree. Frosted with blackberry buttercream and topped with a fresh blackberry.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-terracotta shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Margarita</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Lime flavored cake infused with real tequila. Frosted in tequila lime buttercream and sprinkled with salt.
        </p>
      </div>

      <div class="bg-white p-10 rounded-3xl border-l-[12px] border-brand-brown shadow-sm hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold mb-4">Black Forrest</h3>
        <p class="text-brand-dark-brown text-base leading-relaxed font-medium">
          Chocolate cake infused with cherry Kirsch. Alternately layered with cherry filling and whipped cream frosting. Frosted in whipped cream frosting and topped with maraschino cherries and chocolate shavings.
        </p>
      </div>

    </div>
  </section>

  <section class="text-center py-20 bg-brand-dark-brown rounded-[3rem] text-brand-light-cream shadow-2xl overflow-hidden relative">
    <div class="relative z-10 px-6">
      <h2 class="text-4xl md:text-6xl font-bold mb-6 text-brand-cream!">Ready to Sweeten Your Easter?</h2>
      <p class="text-xl md:text-2xl mb-10 text-brand-cream/80 max-w-2xl mx-auto">
        Order custom treats and signature cakes for pickup in Chicago. Spots fill up fast!
      </p>
      <a href="contact" class="inline-block bg-brand-teal text-white px-12 py-5 rounded-2xl font-bold text-2xl hover:bg-brand-terracotta transition-all shadow-lg transform hover:-translate-y-1">
        Send an Inquiry Now
      </a>
    </div>
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-teal/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-brand-terracotta/10 rounded-full blur-3xl"></div>
  </section>

</main>

</Page>