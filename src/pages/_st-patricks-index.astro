---
import "../styles/global.css";

import Page from "../layouts/index.astro";
---

<Page
 page_title="Sweet Bakes Chicago - Always Nut Free and Allergy Friendly"
  page_description="Sweet Bakes Chicago is a nut-free cottage bakery in Chicago. Order custom cakes and allergy-friendly baked goods with confidence. Safe & delicious!"
>


<header class="bg-brand-light-cream shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="flex justify-center py-6">
                <a href="index" class="flex items-center gap-3">
                    <img src="sweet-bakes-logo-nobg.avif" alt="Sweet Bakes Chicago" class="h-96 w-auto object-contain" />
                </a>
            </div>

            
            <nav class="md:hidden" aria-label="Mobile navigation">
                <div class="flex items-start">
                    
                    <ul role="menu" class="flex-1 space-y-2 text-gray-700 ">
                        <li>
                            <a href="index" role="menuitem" class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900">
                                Home
                            </a>
                        </li>
                        <li>
                            <a href="about-us" role="menuitem" class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900">
                                About
                            </a>
                        </li>
                        <li>
                            <a href="gallery" role="menuitem" class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900">
                                Gallery
                            </a>
                        </li>
                        <li>
                            <a href="contact" role="menuitem" class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900">
                                Contact
                            </a>
                        </li>
                    </ul>

                    
                    <ul role="menu" class="flex-1 space-y-4 text-gray-70 mb-2">
                        
                        <li class="border-l">
                            <ul>
                                <li>
                                    <a href="flavors" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Cake Flavors
                                    </a>
                                </li>
                                <li>
                                    <a href="pricing" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Cake Pricing
                                    </a>
                                </li>
                            </ul>
                        </li>

                        
                        <li class="border-l">
                            <ul class="">
                                <li>
                                    <a href="traditional-cookies" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Traditional Cookies
                                    </a>
                                </li>
                                <li>
                                    <a href="decorated-cookies" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Decorated Cookies
                                    </a>
                                </li>
                            </ul>
                        </li>

                        
                        <li>
                            <ul class="border-l">
                                <li>
                                    <a href="macarons" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900">
                                        Macarons
                                    </a>
                                </li>
                                <li>
                                    <a href="donuts" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Donuts
                                    </a>
                                </li>
                                <li>
                                    <a href="pies" role="menuitem" class="block w-full px-4 py-.5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900">
                                        Pies
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </nav>
            
            <nav class="hidden md:visible md:flex justify-center border-t pt-4 pb-4" aria-label="Main">
                <ul class="md:flex gap-10 text-gray-700 items-center">
                    <li>
                        <a href="index" class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900">Home</a>
                    </li>

                    <li>
                        <a href="about-us" class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900">About Us</a>
                    </li>

                    <li>
                        <a href="gallery" class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900">Gallery</a>
                    </li>

                    
                    <li class="relative">
                        <details class="group relative">
                            <summary class="flex items-center gap-2 px-2 py-1 rounded transition-colors duration-150
             text-gray-700 hover:bg-gray-100 hover:text-gray-900 focus:outline-none
             cursor-pointer list-none" aria-haspopup="true">
                                Products
                                <svg class="w-4 h-4 text-current" viewBox="0 0 20 20" fill="currentColor"
                                    aria-hidden="true">
                                    <path fill-rule="evenodd"
                                        d="M5.23 7.21a.75.75 0 011.06-.02L10 10.67l3.71-3.48a.75.75 0 111.04 1.08l-4.25 4a.75.75 0 01-1.06 0l-4.25-4a.75.75 0 01-.02-1.06z"
                                        clip-rule="evenodd" />
                                </svg>
                            </summary>

                            
                            <div class="dropdown absolute left-1/2 top-full transform translate-x-12 translate-y-1
             w-48 bg-white border rounded-md shadow-lg py-2 z-30
             opacity-0 invisible pointer-events-none transition-all duration-150" role="menu" aria-label="Products">

                                
                                <details id="details-cakes" class="group relative">
                                    <summary class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                 hover:bg-gray-100 hover:text-gray-900 cursor-pointer list-none">
                                        Cakes
                                    </summary>

                                    <div class="submenu absolute left-full top-0 -ml-px w-44 bg-white border rounded-md
                 shadow-md py-2 z-40 translate-x-0.5 opacity-0 invisible pointer-events-none
                 transition-all duration-150" role="menu" aria-label="Cakes">
                                        <a href="flavors" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                                            role="menuitem">Flavors</a>
                                        <a href="pricing" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                                            role="menuitem">Pricing</a>
                                    </div>
                                </details>

                                
                                <details id="details-cookies" class="group relative">
                                    <summary class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                 hover:bg-gray-100 hover:text-gray-900 cursor-pointer list-none">
                                        Cookies
                                    </summary>

                                    <div class="submenu absolute left-full top-0 -ml-px w-44 bg-white border rounded-md
                 shadow-md py-2 z-40 translate-x-0.5 opacity-0 invisible pointer-events-none
                 transition-all duration-150" role="menu" aria-label="Cookies">
                                        <a href="traditional-cookies" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                                            role="menuitem">Traditional Cookies</a>
                                        <a href="decorated-cookies" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                                            role="menuitem">Decorated Cookies</a>
                                        <a href="macarons" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                                            role="menuitem">Macarons</a>
                                    </div>
                                </details>

                                
                                <a href="donuts" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900" role="menuitem">Donuts</a>

                                
                                <a href="pies" class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900" role="menuitem">Pies</a>
                            </div>
                        </details>
                    </li>

                    <li>
                        <a href="contact" class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900">Contact</a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="bg-brand-light-cream font-body text-brand-dark-brown">

  <section class="relative md:h-[70vh] flex items-center justify-center overflow-hidden py-8">
    <img src="st-patricks-day-banner.png" alt="St. Patrick's Day Banner" class="hidden md:block absolute inset-0 w-full w-full object-cover">
     <div class="relative z-10 text-center px-4">
      <h1 class="font-heading text-4xl md:text-5xl mb-4 drop-shadow-md">Feel Lucky with these treats!</h1>
      <p class=" text-xl md:text-2xl mb-8 max-w-2xl mx-auto">Handcrafted sweets to make your St. Paddy's Day celebration extra golden.</p>
      <a href="contact" class="bg-brand-terracotta hover:bg-brand-brown text-brand-cream px-8 py-4 rounded-full font-bold transition-colors duration-300 inline-block">
        Order Your Treats
      </a>
    </div>
  </section>

  <section class="py-16 md:py-24 px-6 max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="rounded-2xl overflow-hidden shadow-xl border-8 border-brand-cream">
         <img src="st-patricks-day-cup-cake-irish-baily-frosting.avif" alt="Bailey's Cupcakes" class="object-cover w-full h-full">
      </div>
      <div class="space-y-6">
        <span class="text-brand-teal font-bold uppercase tracking-widest text-sm">Seasonal Special</span>
        <h2 class="font-heading text-4xl text-brand-terracotta">The Lucky Clover</h2>
        <p class="text-lg leading-relaxed text-brand-brown">
          Perfect for Saint Patrick's Day! This cake and cupcake flavor is made with a delicious <strong>Green Velvet batter</strong>, layered with rich <strong>Mint Chocolate Ganache</strong> filling, and topped with our signature <strong>Bailey's Irish Cream frosting</strong>.
        </p>
        <div class="pt-4">
          <a href="flavors" class="text-brand-brown font-bold border-b-2 border-brand-teal pb-1 hover:text-brand-teal transition-colors">
            View All Seasonal Cakes →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-cream py-16 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl text-brand-brown mb-4">A Taste of the Irish</h2>
        <div class="h-1 w-24 bg-brand-teal mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        
        <div class="group">
          <div class="relative overflow-hidden rounded-full aspect-square mb-6 border-4 border-brand-grey-green">
            <img src="st-patricks-day-decorated-cookie.avif" alt="Decorated Cookies" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
          </div>
          <h3 class="font-heading text-2xl mb-2">Festive Cookies</h3>
          <p class="text-brand-brown mb-4">Sugar cookies hand-piped with shamrocks and gold.</p>
          <a href="decorated-cookies" class="text-brand-terracotta font-bold hover:underline">Shop Cookies</a>
        </div>

        <div class="group">
          <div class="relative overflow-hidden rounded-full aspect-square mb-6 border-4 border-brand-grey-green">
            <img src="chocolate-bourbon-cake.jpg" alt="The Lucky Clover Cake" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
          </div>
          <h3 class="font-heading text-2xl mb-2">Chocolate Bourbon Cake</h3>
          <p class="text-brand-brown mb-4">
            Rich chocolate cake infused with real bourbon. Sub in Guinness beer for a lucky Irish twist.</p>
          <a href="flavors" class="text-brand-terracotta font-bold hover:underline">See Flavors</a>
        </div>

        <div class="group">
          <div class="relative overflow-hidden rounded-full aspect-square mb-6 border-4 border-brand-grey-green">
            <img src="st-patricks-day-pot-of-gold-cake-pops.avif" alt="Pot of Gold Cake Pops" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
          </div>
          <h3 class="font-heading text-2xl mb-2">Pot of Gold Pops</h3>
          <p class="text-brand-brown mb-4">Bite-sized magic at the end of the rainbow.</p>
          <a href="pricing#cake-pops" class="text-brand-terracotta font-bold hover:underline">View Cake Pops</a>
        </div>

      </div>
    </div>
  </section>

  <section class="py-16 text-center bg-brand-brown text-brand-cream">
    <h2 class="font-heading text-3xl mb-8 px-4">Ready to celebrate? Place your custom order today!</h2>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="pricing" class="border-2 border-brand-teal text-brand-teal px-6 py-2 rounded hover:bg-brand-teal hover:text-brand-brown transition-all">Pricing Guide</a>
      <a href="about-us" class="border-2 border-brand-cream text-brand-cream px-6 py-2 rounded hover:bg-brand-cream hover:text-brand-brown transition-all">Our Story</a>
    </div>
  </section>

</main>

</Page>