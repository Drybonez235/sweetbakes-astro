---
import "../styles/global.css";
import { BAKERY_MENU } from '../data/menu';

import Page from "../layouts/index.astro";
---

<Page
  title="Donuts - Sweet Bakes Chicago."
  description="Our selection of artisan donuts and gourmet doughnuts, from classic glazed to unique, hand-dipped specialties."
>
<section class="w-full">
  <div class="w-full h-44 md:h-64 bg-gray-100">
    <img src="/donuts-hero.avif" alt="donuts" class="object-cover w-full h-full" />
  </div>
</section>

<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
   <section class="prose lg:prose-lg">
    <h1 class="text-3xl font-semibold">Fresh Made Donuts</h1>
    <p>Our donuts are made in our nut-free facility. We make all donuts to order. Please contact us for availability, custom requests,
      or rush orders. Donuts are best eaten the day they are made and so we can only gaurentee freshness the day of pick up or delivery.</p>
  </section>
  
  <section class="bg-white rounded-lg p-6 shadow-sm">
  
    <h2 class="text-2xl font-semibold mb-4">Donut Types</h2>
    <p class="mb-4 text-gray-700">Our donuts are hand made to order. Enjoy a fresh yeast donut or a moist cake donut. They can be enjoyed as donut rings or as donut holes. For more flavor, add one of our signature fillings!</p> 
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Fried Cake Donuts</h4>
      <ul class="list-disc list-inside text-gray-700 space-y-1">
          <li>Vanilla</li>
          <li>Chocolate</li>
          <li>Red Velvet</li>
          <li>Apple Cider</li>
       </ul>
      </div>

      <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Traditional Yeast</h4>
      <ul class="list-disc list-inside text-gray-700 space-y-1">
          <li>Ring</li>
          <li>Filled<span class="text-gray-400">+</span></li>
        </ul>
      </div>  
    </div>
  </section>
  <!-- Images -->
  <section class="bg-white rounded-lg p-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <img src="/sugar-donut.avif" alt="Sugar Donut" class="w-full h-36 object-cover rounded shadow-sm" />
      <img src="/chocolate-spronkled-donut.avif" alt="Chocolate donut with sprinkles"
        class="w-full h-36 object-cover rounded shadow-sm" />
      <img src="/strawberry-donut-with-sprinkles.avif" alt="strawberry donut with sprinkles"
        class="w-full h-36 object-cover rounded shadow-sm" />
      <img src="/powedered-donut.avif" alt="Powdered donut" class="w-full h-36 object-cover rounded shadow-sm" />
    </div>
  </section> <!-- Frostings and toppings -->

  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-4">Frostings and Toppings</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mb-2">Traditional Glaze Frostings</h3>
        <ul class="list-disc list-inside text-gray-700 space-y-1">
          <li>Vanilla</li>
          <li>Chocolate</li>
          <li>Strawberry</li>
          <li>Raspberry</li>
          <li>Maple</li>
          <li>Salted Caramel</li>
        </ul>
      </div>

      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mb-2">Sugars / Toppings</h3>
        <ul class="list-disc list-inside text-gray-700 space-y-1">
          <li>Cinnamon</li>
          <li>Spiced Sugar</li>
          <li>Strawberry Sugar</li>
          <li>Raspberry Sugar</li>
          <li>Powdered Sugar</li>
        </ul>
      </div>

      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mb-2">Additional Toppings<span class="text-gray-400">+</span></h3>
        <ul class="list-disc list-inside text-gray-700 space-y-1">
          <li>Sprinkles<span class="text-gray-400">++</span></li>
          <li>Glaze striping</li>
          <li>Oreo crumbles</li>
          <li>Bacon crumbles<span class="text-gray-400">+</span></li>
          <li>Toffee bits<span class="text-gray-400">+</span></li>
        </ul>
      </div>
    </div>
  </section> <!-- Fillings -->

  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-4">Fillings</h2>
    <p class="text-gray-700 mb-3">We offer fruit preserves and other fillings — other fillings may be available upon
      request.</p>
       <div class="p-3 border rounded bg-brand-light-cream">
    <ul class="list-disc list-inside text-gray-700 space-y-1">
      <li>Strawberry</li>
      <li>Raspberry</li>
      <li>Blackberry</li>
      <li>Peach</li>
      <li>Cherry</li>
    </ul>
    </div>
  </section> 
  
  <!-- Pricing -->
  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-4">Pricing</h2>
    <p class=" text-gray-700 mb-4">Pricing is per dozen. Special toppings/fillings may have additional charges.
      Please contact us for specific pricing.</p>

    <div class="overflow-x-auto">
      <table class="min-w-full bg-white rounded-lg shadow-sm divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="text-left px-4 py-3 text-sm font-medium text-gray-700">Item</th>
            <th class="text-right px-4 py-3 text-sm font-medium text-gray-700">Price (per dozen)</th>
          </tr>
        </thead>
        <tbody class="text-gray-700 divide-y divide-gray-100">
          <tr>
            <td class="px-4 py-3">Cake or Yeast Ring Shaped Donuts</td>
            <td class="px-4 py-3 text-right font-medium">${BAKERY_MENU["donuts"].price.toFixed(2)}</td>
          </tr>
          <tr>
            <td class="px-4 py-3">Filled Yeast Donuts</td>
            <td class="px-4 py-3 text-right font-medium">${BAKERY_MENU["filled-donuts"].price.toFixed(2)}</td>
          </tr>
          <tr>
            <td class="px-4 py-3">Mini Donuts <span class="text-sm">+++ (2 dozen minimum)</span></td>
            <td class="px-4 py-3 text-right font-medium">${BAKERY_MENU["mini-donuts"].price.toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="mt-4 text-sm text-gray-600">
      + Additional charges may apply.<br />
      ++ Donuts can be topped with in-stock rainbow sprinkles at no additional cost. Custom sprinkles/cereals are
      subject to availability and may require advanced notice. We are a nut-free bakery — nut-free sprinkles/cereals can
      be difficult to source in specific colors/types; we will do our best with advanced notice.<br />
      +++ 2 dozen minimum purchase for mini donuts unless your order already includes regular size donuts.
    </p>

    <div class="mt-4">
      <a href="/contact"
        class="inline-block bg-brand-teal text-white px-4 py-2 rounded hover:bg-brand-grey-green">Request a quote</a>
    </div>
  </section>
</main>

</Page>