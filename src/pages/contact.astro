---
import "../styles/global.css";

import Page from "../layouts/index.astro";
import Form from "../components/Form.astro"
---

<Page
  title="Contact Sweet Bakes Chicago - Order Inquiry & Location."
  description="Get in touch with us to start your custom order or inquire about custom cakes and baked goods."
>
  
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <section class="bg-brand-light-creamcream border rounded-lg p-6 shadow-sm">
     <h1 class="font-heading text-3xl font-semibold mb-3 text-brand-brown">Contact / Order</h1>

<p class="font-body text-brand-dark-brown mb-4">
  For questions or to place an order please fill out this form and we
  will contact you soon. You can also email us at
  <a href="mailto:sweetbakeschicago@gmail.com"
     class="text-brand-terracotta hover:text-brand-brown hover:underline transition-colors">
     sweetbakeschicago@gmail.com
  </a>
  or call
  <a href="tel:+17738700026" 
     class="text-brand-terracotta hover:text-brand-brown hover:underline transition-colors">
     773‑870‑0026
  </a>.
</p>

<div class="grid grid-cols-1 gap-6">
  <div class="font-body text-brand-dark-brown">
    <h2 class="font-heading text-xl font-semibold text-brand-brown">If requesting a quote, please list the following:</h2>

    <ul class="list-disc list-inside mt-2 space-y-1 marker:text-brand-teal">
      <li>Date of event</li>
      <li>Number of servings (or quantity)</li>
      <li>What treats you are interested in</li>
      <li>Feel free to attach a picture of what you are looking for</li>
    </ul>

    <h3 class="font-heading mt-4 font-semibold text-brand-brown">Important notes</h3>
    <p>
      Filling out this form does not place your order. Everything we make
      is made to order so we ask for <strong class="text-brand-terracotta">2 weeks notice</strong>. SOMETIMES
      exceptions can be made — please contact us if you need a rush order.
    </p>

    <p class="mt-2 italic">
      Payment or a deposit is required at the end of the ordering process.
    </p>
  </div>
</div>

       <Form />
       
    </section>

    <!-- Delivery -->
    <section id="delivery" class="mb-10 bg-white shadow-sm rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-gray-800 mb-3">Delivery</h2>
      <p class="text-gray-700 mb-4">
        There is a <span class="font-medium">$10.00</span> minimum charge for all products delivered.
        See map below for approximate delivery fees. Pricing subject to change
        depending on traffic times and current gas prices.
      </p>

      <div class="w-full bg-gray-50 rounded overflow-hidden shadow-inner flex flex-col items-center">
        <img src="/delivery-map.avif" alt="Delivery area map" class="w-full md:width-auto object-cover" />
      </div>
    </section>
  </main>

</Page>