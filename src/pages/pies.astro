---
import "../styles/global.css";
import { BAKERY_MENU } from '../data/menu';
import Page from "../layouts/index.astro";
import CTA from "../components/CallToAction.astro"
---
<Page
  title="Pies - Sweet Bakes Chicago."
  description="Explore our homemade pies featuring nut free and allergy friendly ingredients."
>
<section class="w-full">
    <div class="w-full h-44 md:h-64 bg-gray-100">
        <img src="/pie-day-pie.avif" alt="donuts" class="object-cover w-full h-full" />
    </div>
</section>

<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <section class="prose lg:prose-lg">
    <h1 class="text-3xl font-semibold">Classic American Pie</h1>
    <p>9&quot; round — flaky, golden brown crust filled with a variety of flavors. Fresh baked and oh so delicious!</p>
  </section>

  

    <section class="bg-white border rounded-lg p-6 shadow-sm">
        <h2 class="text-2xl font-semibold mb-4">Flavors</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 text-gray-700">
            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Apple</p>
                <p class="text-sm text-gray-600  mt-1">A classic, comforting blend of sweet and tart apples baked to
                    perfection in a flaky crust.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Blueberry</p>
                <p class="text-sm text-gray-600 mt-1">Bursting with sweet and juicy blueberries, this pie offers a
                    delightful taste of summer.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Cherry</p>
                <p class="text-sm text-gray-600 mt-1">A vibrant and tangy pie filled with plump, red cherries that offer
                    a perfect balance of sweet and tart.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Chocolate</p>
                <p class="text-sm text-gray-600 mt-1">Rich, decadent chocolate in a creamy filling, perfect for any
                    chocolate lover.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Apple Crumble</p>
                <p class="text-sm text-gray-600 mt-1">Sweet and tender baked apples topped with a buttery, crunchy oat
                    crumble for a delightful texture.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Peach</p>
                <p class="text-sm text-gray-600 mt-1">Sun-ripened peaches baked into a sweet and tender filling,
                    embodying the taste of a warm summer day.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Triple Berry</p>
                <p class="text-sm text-gray-600 mt-1">A delightful medley of three seasonal berries, offering a complex
                    and fruity flavor profile.</p>
            </div>

            <div class="p-3 border rounded bg-brand-light-cream">
                <p class="font-semibold text-brand-brown">Pretzel</p>
                <p class="text-sm text-gray-600 mt-1">Think pecan pie but with pretzels instead of pecans.</p>
            </div>
        </div>
    </section>

    </section>
    <section class="bg-white border rounded-lg p-6 shadow-sm">
        <h2 class="text-xl font-heading text-brand-brown font-semibold mb-3">
            Ordering
        </h2>
        <p class="text-brand-dark-brown mb-3">
            Pies are sold full-size (9&quot; round) at ${BAKERY_MENU["pie"].price.toFixed(2)} each. Special requests,
            dietary accommodations, or custom orders may incur additional charges —
            please contact us to discuss.
        </p>

        <div>
        
    <CTA 
      message="Click here to order"
      url="/contact"
      variant="secondary"
      size="md"
      isExternal= {false}
      />
        </div>
    </section>
</main>

</Page>