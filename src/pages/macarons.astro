---
import "../styles/global.css";
import { BAKERY_MENU } from '../data/menu';
import Page from "../layouts/index.astro";
import PageHero from "../components/PageHero.astro"
---

<Page
  title="Macarons - Sweet Bakes Chicago."
  description="Discover our delicate and colorful French macarons, available in a variety of flavors and all nut free."
>
<PageHero 
  pageName="Macarons"
image="/macarons-hero-page.avif"
alt="Sunflower baked macarons in different pastel colors."
height={1220}
width={1421}
></PageHero>
<!-- <section class="w-full">
    <div class="w-full h-44 md:h-64 bg-gray-100">
        <img src="/macarons-hero-page.avif" alt="Macarons hero" class="object-cover w-full h-full" />
    </div>
</section> -->



<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
  <section class="prose lg:prose-lg">
    <h1 class="text-3xl font-semibold">Sunflower Seed Macarons</h1>
    <p class=" text-gray-600">This luxurious treat has been a French delicacy for hundreds of years. Known for its light and airy textures, this desert is made through an intricate process. Only the most experienced bakers attempt them. Try our nut-free twist on this classic French cookie.</p>
  </section>

  <section class="bg-white rounded-lg p-6">
    <div class="gap-4 flex justify-center items-center ">
      <img src="/galaxy-macarons-500x500.avif" alt="Galaxy colored macarons" class="w-full h-36 object-cover rounded shadow-sm" />
      <img src="/macarons-1-650x433.avif" alt="Build your own macarons example"
        class="w-full h-36 object-cover rounded shadow-sm" />
    </div>
  </section> 
<section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Signature Flavors</h2>
    <p class="mb-4 text-gray-600">Naturally gluten free! Dairy free options available. Additional charges may
      apply.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Birthday Cake</h3>
        <p class="text-sm text-gray-700 mt-2">Vanilla shell with Italian buttercream filling rolled in colorful
          sprinkles.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macarons"].price.toFixed(2)} a dozen</p>
      </article>

      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Tropical Summer</h3>
        <p class="text-sm text-gray-700 mt-2">Lemon shell with mango fruit preserve and Italian buttercream filling.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macaron-special"].price.toFixed(2)} a dozen</p>
      </article>

      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Cookies and Cream</h3>
        <p class="text-sm text-gray-700 mt-2">Vanilla shell with Oreo Italian buttercream filling.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macaron-special"].price.toFixed(2)} a dozen</p>
      </article>

      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Chocolate Raspberry</h3>
        <p class="text-sm text-gray-700 mt-2">Raspberry shell filled with chocolate ganache and raspberry puree.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macarons"].price.toFixed(2)} a dozen</p>
      </article>

      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Strawberry Lemon</h3>
        <p class="text-sm text-gray-700 mt-2">Strawberry shell with lemon Italian buttercream.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macarons"].price.toFixed(2)} a dozen</p>
      </article>

      <article class="border rounded-lg p-4 bg-brand-light-cream">
        <h3 class="font-semibold">Caramel Mocha</h3>
        <p class="text-sm text-gray-700 mt-2">Coffee shell with salted caramel filling and dark chocolate ganache.</p>
        <p class="mt-3 font-medium text-gray-800">${BAKERY_MENU["macarons"].price.toFixed(2)} a dozen</p>
      </article>
    </div>
  </section>

  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Build Your Own</h2>
    <p class="mb-3 text-gray-700">Choose a shell flavor from our many options or request a custom flavor. Then choose a filling to go in-between the shell. You can add an additional fruit filling for an extra charge. 
     </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mb-2">Shell flavors</h3>
        <ul class="list-disc list-inside space-y-1 text-gray-700">
          <li>Vanilla</li>
          <li>Chocolate</li>
          <li>Coffee</li>
          <li>Strawberry</li>
          <li>Raspberry</li>
          <li>Lemon</li>
        </ul>
      </div>

      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mb-2">Cream Fillings</h3>
        <ul class="list-disc list-inside space-y-1 text-gray-700">
          <li>Italian Buttercream</li>
          <li>American Buttercream</li>
          <li>Chocolate Ganache</li>
          <li>Salted Caramel</li>
        </ul>
      </div>
      <div class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold mt-4 mb-2">Fruit Fillings</h3>
        <ul class="list-disc list-inside space-y-1 text-gray-700">
          <li>Strawberry</li>
          <li>Raspberry</li>
          <li>Blackberry</li>
          <li>Peach</li>
          <li>Mango</li>
        </ul>
      </div>
    </div>
  </section>

  

  <section class="bg-brand-light-cream border rounded-lg p-6 shadow-sm">
    <p class="text-gray-700">
      Orders and pricing may vary depending on flavors, fillings, and
      color/decoration complexity. Please contact us with desired flavors,
      quantities, and event date. Minimums may apply for some custom orders.
    </p>

    <div class="mt-4">
      <a href="/contact"
        class="inline-block bg-brand-teal text-white px-4 py-2 rounded hover:bg-brand-grey-green">Enjoy Nut Free Macarons</a>
    </div>
  </section>
</main>

</Page>