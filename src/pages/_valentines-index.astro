---
import "../styles/global.css";

import Page from "../layouts/index.astro";
---
<Page
  title="Sweet bakes"
  description="Awesome cakes!"
>

    <section class="relative bg-brand-light-cream py-16 md:py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center">
            <div class="md:w-1/2 text-center md:text-left space-y-6">
                <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wider text-brand-terracotta uppercase bg-red-50 rounded-full">
                    New Year, Sweeter Moments
                </span>
                <h1 class="text-4xl md:text-6xl font-heading font-bold text-brand-dark-brown leading-tight">
                    Love at First <br/><span class="text-brand-terracotta">Bite.</span>
                </h1>
                <p class="text-lg text-gray-600 max-w-lg">
                    Celebrate Valentine's Day with handcrafted sweets from Sweet Bakes Chicago. From custom decorated cookies to our signature cake pop bouquets.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
                    <a href="contact" class="bg-brand-terracotta text-white px-8 py-3 rounded-md font-medium hover:bg-opacity-90 transition">Order for Valentine's</a>
                    <a href="pricing#cake-pops" class="border border-brand-brown text-brand-brown px-8 py-3 rounded-md font-medium hover:bg-brand-light-cream transition">View Cake Pops</a>
                </div>
            </div>
            <div class="md:w-1/2 mt-12 md:mt-0 px-4">
                <div class="aspect-square bg-gray-200 rounded-2xl shadow-xl overflow-hidden flex items-center justify-center border-4 border-white">
                <img src="valentines-day-cake-pop.avif" alt="Valentines Decorated Cookies that look like sweet tarts" class="w-full h-auto rounded-lg mb-6 shadow-md object-cover">
                </div>
            </div>
        </div>
    </section>

    <section class="py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-heading font-bold text-brand-brown">Valentine’s Favorites</h2>
            <div class="h-1 w-20 bg-brand-terracotta mx-auto mt-4"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="group relative overflow-hidden rounded-xl bg-gray-50 border border-gray-100 p-6 transition-all hover:shadow-md">
                <div class="aspect-video bg-gray-200 rounded-lg mb-6 flex items-center justify-center">
                    <img src="valentines-decorated-cookies-sweet-tarts.avif" alt="Custom decorated cookies with sweet tart themes" class="w-full h-auto rounded-lg mb-6 shadow-md object-cover">
                </div>
                <h3 class="text-2xl font-semibold text-brand-brown mb-2">Decorated Cookies</h3>
                <p class="text-gray-600 mb-4">Custom-iced sugar cookies designed to melt hearts. Perfect for gifting or "thinking of you" treats.</p>
                <a href="decorated-cookies#custom_cookies" class="text-brand-teal font-medium hover:underline flex items-center gap-1">
                    See Designs <span>&rarr;</span>
                </a>
            </div>

            <div class="group relative overflow-hidden rounded-xl bg-gray-50 border border-gray-100 p-6 transition-all hover:shadow-md">
                <div class="aspect-video bg-gray-200 rounded-lg mb-6 flex items-center justify-center">
                    <img src="valentines-day-rose-cake-pops.avif" alt="Valentines Cake Pop Rose Bouquet" class="w-full h-auto rounded-lg mb-6 shadow-md object-cover">
                </div>
                <h3 class="text-2xl font-semibold text-brand-brown mb-2">Cake Pop Bouquets</h3>
                <p class="text-gray-600 mb-4">A delicious alternative to flowers! Our bouquets are hand-rolled, dipped, and beautifully arranged.</p>
                <a href="contact" class="text-brand-teal font-medium hover:underline flex items-center gap-1">
                    Pre-order Bouquet <span>&rarr;</span>
                </a>
            </div>
        </div>
    </section>

    <section class="bg-brand-teal text-white py-16">
    <div class="max-w-5xl mx-auto px-4">
        <div class="flex flex-col md:flex-row items-center gap-10">
            <div class="md:w-1/3">
                <div class="">
                     <img src="valentines-decorated-cookies.avif" alt="Valentines Cake Pop Rose Bouquet" class="w-full mb-6 shadow-md object-cover rounded-full">
                </div>
            </div>
            
            <div class="md:w-2/3 text-center md:text-left">
                <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4 text-brand-light-cream">The Safe Choice for School Parties</h2>
                <p class="text-xl mb-6 leading-relaxed">
                    Planning a classroom celebration? Sweet Bakes Chicago is a nut-free facility. Give parents peace of mind and keep every student included with treats that are as safe as they are delicious.
                </p>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="bg-brand-light-cream/20 p-1 rounded-full text-brand-light-cream">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span>Safe for Nut-Free Classrooms</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="bg-brand-light-cream/20 p-1 rounded-full text-brand-light-cream">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span>Individual Wrapping Availible</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="bg-brand-light-cream/20 p-1 rounded-full text-brand-light-cream">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span>Put classmates names on the cookies!</span>
                    </div>
                </div>

                <a href="decorated-cookies#decorated-cookie-pricing" class="inline-block bg-brand-terracotta text-white px-10 py-4 rounded-md font-bold hover:brightness-110 transition shadow-lg">
                    View Cookie Options
                </a>
            </div>
        </div>
    </div>
</section>
</Page>