---
import "../styles/global.css";
import CTA from "../components/CallToAction.astro";
import Page from "../layouts/index.astro";

const aboutMetadata = {
  title: "Sweet Bakes Chicago - Our Story & Mission",
  description: "Learn about Sara Williams and our 100% nut-free cottage bakery serving the Chicago area."
};
---

<Page title={aboutMetadata.title} description={aboutMetadata.description}>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">
    
    <section class="text-center space-y-6">
      <h1 class="text-4xl md:text-6xl font-bold text-[var(--color-brand-terracotta)]">
        100% Nut-Free & Heart-Led
      </h1>
      <p class="text-2xl text-[var(--color-brand-brown)] max-w-2xl mx-auto italic">
        "Because everyone deserves a treat that is both safe and delicious."
      </p>
      
      <div class="mt-8 p-8 bg-[var(--color-brand-light-cream)] border-2 border-[var(--color-brand-teal)] rounded-2xl max-w-3xl mx-auto shadow-sm">
        <p class="text-xl md:text-2xl text-[var(--color-brand-dark-brown)]">
          Sweet Bakes Chicago is a <strong>Tree Nut and Peanut FREE Facility</strong>. Located on the northwest side of Chicago, we ensure every ingredient is sourced from nut-free manufacturers. 
          We also offer select gluten, dairy, and sugar-free options.
        </p>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="flex justify-center">
        <div class="relative">
          <img 
            src="/sara-300x300.avif" 
            alt="Sara Williams" 
            class="rounded-full shadow-xl w-64 h-64 md:w-80 md:h-80 object-cover border-8 border-white"
          />
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-[var(--color-brand-teal)] rounded-full -z-10 opacity-20"></div>
        </div>
      </div>

      <div class="space-y-6">
        <h2 class="text-4xl font-semibold text-[var(--color-brand-brown)]">Meet Sara</h2>
        <div class="space-y-4 text-xl md:text-2xl text-[var(--color-brand-dark-brown)] leading-relaxed">
          <p>
            With over 20 years of experience and training from pastry icons like <strong>Collette Peters</strong>, 
            my journey with flour and sugar started as a high school hobby that blossomed into a lifelong obsession.
          </p>
          <p>
            In 2015, my world changed when my daughter was diagnosed with a tree nut allergy. I saw firsthand 
            how difficult it was to find high-quality, safe treats. That’s when <strong>Sweet Bakes Chicago</strong> 
            became a dedicated nut-free bakery.
          </p>
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <div class="text-center">
        <h3 class="text-3xl font-heading text-[var(--color-brand-brown)] mb-2">Baked with Family in Mind</h3>
        <p class="text-lg text-[var(--color-brand-grey-green)]">My inspiration and my favorite taste-testers.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-2">
          <img 
            src="/sara-and-family.avif" 
            alt="Sara and her family" 
            class="rounded-2xl w-full aspect-[3/4] object-cover shadow-md hover:scale-[1.01] transition-transform" 
          />
        </div>
        <div class="space-y-2">
          <img 
            src="/saras-children.avif" 
            alt="Sara's children posing at the Lincoln Park Zoo" 
            class="rounded-2xl w-full aspect-[3/4] object-cover shadow-md hover:scale-[1.01] transition-transform" 
          />
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-brand-brown)] rounded-3xl p-8 md:p-16 text-white text-center">
      <h3 class="text-4xl font-heading mb-6">Let’s Make Something Sweet Together</h3>
      <p class="max-w-xl mx-auto mb-10 text-[var(--color-brand-light-cream)] text-xl">
        From custom event treats to signature donuts, we’re ready to help you celebrate safely.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <CTA message="Place an Order" url="/contact" variant="secondary" size="lg" />
        <CTA message="View Our Gallery" url="/gallery" variant="outline" size="lg" className="!border-white !text-white hover:!bg-white hover:!text-[var(--color-brand-brown)]" />
      </div>

      <footer class="mt-16 pt-8 border-t border-white/20 text-lg text-white/80 italic">
        Note: Our products are produced in a home kitchen not inspected by a health department. 
        Facility may contain wheat, milk, soy, egg, and shellfish.
      </footer>
    </section>

  </main>
</Page>