---
import "../styles/global.css";

import Page from "../layouts/index.astro";
---
<Page
page_title="Sweet Bakes Chicago - Always Nut Free and Allergy Friendly"
  page_description="Sweet Bakes Chicago is a nut-free cottage bakery in Chicago. Order custom cakes and allergy-friendly baked goods with confidence. Safe & delicious!"
>

<section class="w-full">
  <div class="w-full h-64 md:h-96 bg-gray-100">
    <img src="halloween_hero.avif" alt="Hero - Sweet Bakes Chicago" class="object-cover w-full h-full" />
  </div>
</section>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <section class="text-center">
    <h2 class="text-2xl md:text-3xl font-semibold">Order your nut free treats today!</h2>
    <div class="mt-6 flex justify-center">
      <img src="be_allergy_safe_pumpkin.avif" alt="Nut free treats" class="w-auto object-cover rounded-lg shadow-sm" />
    </div>
  </section>

  <section class="mt-12 text-2xl">
    <h3 class="text-6xl font-bold mb-6 text-center" style="font-family: 'Creepster', cursive; color:#D9480F;">
      fall treat ideas
    </h3>
     <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

      <!-- CUPCAKES - Link to # (No specific link provided) -->
      <a href="pricing#cupcakes" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="jack-o-lantern-cupcakes.webp" 
            alt="Pumpkin Cupcakes" 
            class="object-cover w-full h-full" 
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Cupcakes
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting @ $35 a dozen</p>
        </div>
      </a>

      <!-- COOKIES - Link to decorated-cookies -->
      <a href="decorated-cookies" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="gengerbreak_skelotons.jpeg" 
            alt="Skeloton Cookie" 
            class="object-cover w-full h-full"
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Cookies
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting @ $34 a dozen</p>
        </div>
      </a>

      <!-- DONUTS - Link to donuts -->
      <a href="donuts" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="halloween_donuts.avif" 
            alt="Halloween Donuts" 
            class="object-cover w-full h-full"
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Donuts
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting @ $30 a dozen</p>
        </div>
      </a>

      <!-- PIES - Link to pies -->
      <a href="pies" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="pretzel_pie.avif" 
            alt="Pretzel Pie" 
            class="object-cover w-full h-full" 
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Pies
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting @ $27</p>
        </div>
      </a>

      <!-- CAKE - Link to flavors -->
      <a href="flavors" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="carmal_cake.avif" 
            alt="White carmel cake" 
            class="object-cover w-full h-full" 
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Cake
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting at $35</p>
        </div>
      </a>

      <!-- MACARONS - Link to macarons -->
      <a href="macarons" class="block h-full bg-white border border-gray-200 rounded-xl overflow-hidden shadow-lg flex flex-col transition duration-300 transform hover:scale-[1.03] hover:shadow-2xl hover:border-orange-400 focus:outline-none focus:ring-4 focus:ring-orange-300">
        <div class="h-40 bg-gray-100">
          <img 
            src="halloween_macaroons.avif" 
            alt="Halloween Macarons" 
            class="object-cover w-full h-full" 
          />
        </div>
        <div class="p-4 mt-auto">
          <h4 class="text-2xl font-bold mb-1" style="font-family: 'Creepster', cursive; color:#F97316;">
            Macarons
          </h4>
          <p class="font-extrabold mt-2 text-lg text-purple-700">Starting @ $40 a dozen</p>
        </div>
      </a>

    </div>
  </section>
</main>

</Page>