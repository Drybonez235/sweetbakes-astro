---
import "../styles/global.css";
import { BAKERY_MENU } from '../data/menu';

import Page from "../layouts/index.astro";
---

<Page
  page_title="Traditional Cookies - Sweet Bakes Chicago Classics."
  page_description="Indulge in our classic, fresh-baked cookies like chocolate chip, oatmeal raisin, and snickerdoodles—perfect for any occasion."
>

<section class="w-full">
  <div class="w-full h-44 md:h-64 bg-gray-100">
    <img src="cookies-hero.avif" alt="cookies I want to eat" class="object-fill w-full h-full" />
  </div>
</section>

<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
  <section class="prose lg:prose-lg">
    <h1 class="text-3xl font-semibold">
      Traditional Cookies & Specialties
    </h1>
    <p class="text-sm text-gray-600">
      Gluten and dairy free options are available for many of our cookies.
      Additional charges may apply — please contact us for specifics.
    </p>
  </section>

  <section id="traditional_cookies" class="bg-white shadow-sm rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Traditional Cookies</h2>
    <p class="text-gray-700 mb-2">
      Enjoy biting into our homemade cookies that have the perfect balance of a crunchy outside, and a soft gooey inside. Gluten and dairy free options available. Additional charges apply.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Classics</h4>
        <ul class="mt-2 text-sm space-y-1">
          <li class="duration-200 hover:scale-103">Chocolate Chip</li>
          <li class="duration-200 hover:scale-103">Double Chocolate Chip</li>
          <li class="duration-200 hover:scale-103">Oatmeal</li>
          <li class="duration-200 hover:scale-103">Snickerdoodle</li>
        </ul>
      </div>
      <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Holiday</h4>
        <ul class="mt-2 text-sm space-y-1">
          <li class="duration-200 hover:scale-103">Gingerbread Crinkle</li>
          <li class="duration-200 hover:scale-103">Vanilla Sugar</li>
          <li class="duration-200 hover:scale-103">White Chocolate Chip</li>
        </ul>
      </div>
       <p class="text-2xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101">
        ${BAKERY_MENU["cookies-traditional"].price.toFixed(2)} per dozen
        </p>
      </div>
    </div>
  </section>

  <section id="signature_cookies" class="bg-white shadow-sm rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Signature Cookies</h2>
    <p class="mb-4 text-sm text-gray-600">
      Gluten, and dairy free options available. Additional charges apply.
    </p>

    <div class="flex justify-center gap-8 pb-2 mb-4 overflow-x-auto">
      <img src="strawberry-haze.avif" alt="strawberry and cream cheese cookie"
        class="w-40 h-28 object-cover rounded shadow-sm flex-shrink-0" />
      <img src="carmel-cookie.avif" alt="Carmel filled cookie"
        class="w-40 h-28 object-cover rounded shadow-sm flex-shrink-0" />
      <img src="campfire-cookie.avif" alt="Double dark chocolate chip cookie"
        class="w-40 h-28 object-cover rounded shadow-sm flex-shrink-0" />
      <img src="macarons-cookie.avif" alt="macarons" class="w-40 h-28 object-cover rounded shadow-sm flex-shrink-0" />
    </div>

    <div class="grid gap-6">
      <article class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold">Caramel Apple Cider</h3>
        <p class="text-gray-700 mt-2">
          Soft and chewy apple cider sugar cookie with real caramel chips.
          Or ask for it “Stuffed” for a caramel center. Heat it over a fresh
          hot cup of tea or apple cider for a gooey fall treat.
        </p>
        <p class="text-xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101">
        ${BAKERY_MENU["cookies-traditional"].price.toFixed(2)} per dozen
    </p>
      </article>

      <article class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold">Strawberry Haze</h3>
        <p class="text-gray-700 mt-2">
          Delicious strawberry and cream cheese cookie rolled "pinwheel
          style".
        </p>
        <p class="text-xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101">
        ${BAKERY_MENU["cookies-special"].price.toFixed(2)} per dozen
    </p>
      </article>

      <article class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold">Wookie Cookie</h3>
        <p class="text-gray-700 mt-2">
          A double chocolate chip cookie deep fried in funnel cake batter.
          Dusted with powdered sugar. Now that's one monster cookie!
        </p>
       <p class="text-xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101">
        ${BAKERY_MENU["cookies-special"].price.toFixed(2)} per dozen
    </p>
      </article>

      <article class="p-3 border rounded bg-brand-light-cream">
        <h3 class="font-semibold">Campfire Cookies</h3>
        <p class="text-gray-700 mt-2">
          Marshmallows and graham cracker bits inside of a chocolate chip OR
          double chocolate chip cookie. A soft and gooey treat with no
          campfire required!
        <p class="text-xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101">
        ${BAKERY_MENU["cookies-traditional"].price.toFixed(2)} per dozen
    </p>
      </article>
    </div>
  </section>

  <section id="biscotti" class="bg-white shadow-sm rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Biscotti</h2>
    <p class="mb-4 text-gray-700">
      A deliciously crunchy twice baked biscuit cookie. A perfect component
      to a hot cup of coffee or tea. Gluten, and dairy free options available. Additional charges apply.
    </p>
    <div class="flex justify-center gap-8 pb-2 mb-4 overflow-x-auto">
        <img src="biscotti-rasberry.jpeg" alt="Biscotti with rasberry"
          class="w-1/2 h-28 object-cover rounded shadow-sm" />
        <img src="chocolate-biscotti.jpeg" alt="Biscotti chocolate" class="w-1/2 h-28 object-cover rounded shadow-sm" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
     <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Chocolates</h4>
        <ul class="mt-2 text-sm space-y-1">
          <li class="duration-200 hover:scale-103">Chocolate</li>
          <li class="duration-200 hover:scale-103">Triple Chocolate</li>
          <li class="duration-200 hover:scale-103">Mocha</li>
          <li class="duration-200 hover:scale-103">Chocolate Chip</li>
          <li class="duration-200 hover:scale-103">Chocolate Cardamom</li>
        </ul>
      </div>
      <div class="p-3 border rounded bg-brand-light-cream">
        <h4 class="font-semibold">Fruit and Spice</h4>
        <ul class="mt-2 text-sm space-y-1">
          <li class="duration-200 hover:scale-103">Vanilla</li>
          <li class="duration-200 hover:scale-103">Cinnamon Toffee</li>
          <li class="duration-200 hover:scale-103">Lemon</li>
          <li class="duration-200 hover:scale-103">Cranberry Orange</li>
          <li class="duration-200 hover:scale-103">Mango Ginger</li>
        </ul>
      </div>
    </div>
    <p class="text-2xl font-semibold font-heading text-brand-brown duration-200 hover:scale-101 mt-2">
        ${BAKERY_MENU["cookies-traditional"].price.toFixed(2)} per dozen
    </p>
  </section>

  <!-- Macarons -->
  <section id="macarons" class="bg-white shadow-sm rounded-lg p-6 shadow-sm">
    <h2 class="text-2xl font-semibold mb-2">Macarons</h2>
    <p class="text-gray-700 mb-3">
      Made with sunflower seed flour instead of traditional almond flour.
      These French-style sandwich cookies can be filled with a variety of
      frostings or preserves. Gluten and dairy free options may be
      available; additional charges may apply.
    </p>
    <p class="text-sm text-indigo-600">
      <a href="macarons" class="hover:underline">Click here for more information</a>
    </p>
  </section>
</main>

</Page>