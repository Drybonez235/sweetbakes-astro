---
// FlavorGrid.astro
interface Category {
  title: string;
  items: string[];
}

interface Props {
  sectionTitle: string;
  subHeading: string;
  categories: Category[]; // Array of objects for dynamic categories
  backgroundImage?: string; // Optional background image
}

const { 
  sectionTitle, 
  subHeading, 
  categories, 
  backgroundImage 
} = Astro.props;

// Determine if we should use the background image or a solid brand color
const sectionStyle = backgroundImage 
  ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: center;` 
  : `background-color: bg-white;`;
---

<section 
  class="rounded-lg p-6 shadow-sm mb-8" 
  style={sectionStyle}
>
  <h2 class="text-3xl font-semibold mb-4 text-[var(--color-brand-light-cream)]">
    {sectionTitle}
  </h2>
  
  <p class="mb-6 text-sm font-semibold text-[var(--color-brand-light-cream)] max-w-2xl">
    {subHeading}
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {categories.map((category) => (
      <div class="p-4 border rounded bg-[var(--color-brand-light-cream)] shadow-sm">
        <h4 class="font-semibold text-[var(--color-brand-dark-brown)] border-b border-[var(--color-brand-grey-green)] pb-2 mb-2">
          {category.title}
        </h4>
        <ul class="mt-2 text-sm space-y-1">
          {category.items.map((item) => (
            <li class="duration-200 hover:scale-105 hover:text-[var(--color-brand-terracotta)] cursor-default">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
