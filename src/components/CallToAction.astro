---
// CallToAction.astro
interface Props {
  message: string;
  url: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'md' | 'lg';
  isExternal?: boolean;
  className?: string; // For occasional one-off margin adjustments
}

const { 
  message, 
  url, 
  variant = 'primary', 
  size = 'md', 
  isExternal = false,
  className = "" 
} = Astro.props;

const variants = {
  primary: "bg-[var(--color-brand-terracotta)] text-white hover:bg-[var(--color-brand-dark-brown)]",
  secondary: "bg-[var(--color-brand-teal)] text-white hover:bg-[var(--color-brand-grey-green)]",
  outline: "border-2 border-[var(--color-brand-brown)] text-[var(--color-brand-brown)] hover:bg-[var(--color-brand-brown)] hover:text-white"
};

const sizes = {
  md: "px-6 py-2 text-base",
  lg: "px-8 py-4 text-xl font-bold uppercase tracking-wide"
};
---

<a 
  href={url} 
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class:list={[
    "inline-block rounded-md transition-colors duration-200 text-center font-body",
    variants[variant],
    sizes[size],
    className
  ]}
>
  {message}
</a>