---

---

<header class="bg-brand-light-cream shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Logo (centered) -->
    <div class="flex justify-center py-6">
      <a href="/" class="flex items-center gap-3">
        <img
          src="sweet-bakes-logo-nobg.avif"
          alt="Sweet Bakes Chicago"
          class="h-96 w-auto object-contain"
        />
      </a>
    </div>

    <!-- Mobile navigation-->
    <nav class="md:hidden" aria-label="Mobile navigation">
      <div class="flex items-start">
        <!-- LEFT COLUMN -->
        <ul role="menu" class="flex-1 space-y-2 text-gray-700">
          <li>
            <a
              href="/"
              role="menuitem"
              class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900"
            >
              Home
            </a>
          </li>
          <li>
            <a
              href="/about-us"
              role="menuitem"
              class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/gallery"
              role="menuitem"
              class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900"
            >
              Gallery
            </a>
          </li>
          <li>
            <a
              href="/contact"
              role="menuitem"
              class="block w-full px-4 py-2 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900"
            >
              Contact
            </a>
          </li>
        </ul>

        <!-- RIGHT COLUMN (products, grouped) -->
        <ul role="menu" class="flex-1 space-y-4 text-gray-70 mb-2">
          <!-- Cake group: flavors + pricing (closer together) -->
          <li class="border-l">
            <ul>
              <li>
                <a
                  href="/flavors"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Cake Flavors
                </a>
              </li>
              <li>
                <a
                  href="/pricing"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Cake Pricing
                </a>
              </li>
            </ul>
          </li>

          <!-- Cookies group: closer together -->
          <li class="border-l">
            <ul class="">
              <li>
                <a
                  href="/traditional-cookies"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Traditional Cookies
                </a>
              </li>
              <li>
                <a
                  href="/decorated-cookies"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Decorated Cookies
                </a>
              </li>
            </ul>
          </li>

          <!-- Donut + Pie + Macrons group (very close together) -->
          <li>
            <ul class="border-l">
              <li>
                <a
                  href="/macarons"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                  text-gray-700 hover:bg-gray-100 hover:text-gray-900
                  focus:bg-gray-100 focus:text-gray-900"
                >
                  Macarons
                </a>
              </li>
              <li>
                <a
                  href="/donuts"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Donuts
                </a>
              </li>
              <li>
                <a
                  href="/pies"
                  role="menuitem"
                  class="block w-full px-4 py-5 rounded transition-colors duration-150
                      text-gray-700 hover:bg-gray-100 hover:text-gray-900
                      focus:bg-gray-100 focus:text-gray-900"
                >
                  Pies
                </a>
              </li>
            </ul>
          </li>
        </ul>
      </div>
    </nav>
    <!-- Desktop Nav-->
    <nav
      class="hidden md:visible md:flex justify-center border-t pt-4 pb-4"
      aria-label="Main"
    >
      <ul class="md:flex gap-10 text-gray-700 items-center">
        <li>
          <a
            href="/"
            class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900"
            >Home</a
          >
        </li>

        <li>
          <a
            href="/about-us"
            class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900"
            >About Us</a
          >
        </li>

        <li>
          <a
            href="/gallery"
            class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900"
            >Gallery</a
          >
        </li>

        <!-- Products dropdown using details/summary (no JS) -->
        <li class="relative">
          <details class="group relative">
            <summary
              class="flex items-center gap-2 px-2 py-1 rounded transition-colors duration-150
             text-gray-700 hover:bg-gray-100 hover:text-gray-900 focus:outline-none
             cursor-pointer list-none"
              aria-haspopup="true"
            >
              Products
              <svg
                class="w-4 h-4 text-current"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M523 721a7575 0 01106-02L10 1067l371-348a7575 0 11104 108l-425 4a7575 0 01-106 0l-425-4a7575 0 01-02-106z"
                  clip-rule="evenodd"></path>
              </svg>
            </summary>

            <!-- Main dropdown: anchored to bottom of trigger -->
            <div
              class="dropdown absolute left-1/2 top-full transform translate-x-12 translate-y-1
             w-48 bg-white border rounded-md shadow-lg py-2 z-30
             opacity-0 invisible pointer-events-none transition-all duration-150"
              role="menu"
              aria-label="Products"
            >
              <!-- Cakes (nested details for click-to-open on touch) -->
              <details id="details-cakes" class="group relative">
                <summary
                  class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                 hover:bg-gray-100 hover:text-gray-900 cursor-pointer list-none"
                >
                  Cakes
                </summary>

                <div
                  class="submenu absolute left-full top-0 -ml-px w-44 bg-white border rounded-md
                 shadow-md py-2 z-40 translate-x-05 opacity-0 invisible pointer-events-none
                 transition-all duration-150"
                  role="menu"
                  aria-label="Cakes"
                >
                  <a
                    href="/flavors"
                    class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                    role="menuitem">Flavors</a
                  >
                  <a
                    href="/pricing"
                    class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                    role="menuitem">Pricing</a
                  >
                </div>
              </details>

              <!-- Cookies (nested details) -->
              <details id="details-cookies" class="group relative">
                <summary
                  class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                 hover:bg-gray-100 hover:text-gray-900 cursor-pointer list-none"
                >
                  Cookies
                </summary>

                <div
                  class="submenu absolute left-full top-0 -ml-px w-44 bg-white border rounded-md
                 shadow-md py-2 z-40 translate-x-05 opacity-0 invisible pointer-events-none
                 transition-all duration-150"
                  role="menu"
                  aria-label="Cookies"
                >
                  <a
                    href="/traditional-cookies"
                    class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                    role="menuitem">Traditional Cookies</a
                  >
                  <a
                    href="/decorated-cookies"
                    class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                    role="menuitem">Decorated Cookies</a
                  >
                  <a
                    href="/macarons"
                    class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                    hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                    role="menuitem">Macarons</a
                  >
                </div>
              </details>

              <!-- Donuts -->
              <a
                href="/donuts"
                class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                role="menuitem">Donuts</a
              >

              <!-- Pies -->
              <a
                href="/pies"
                class="block px-4 py-2 text-sm text-gray-700 transition-colors duration-150
                hover:bg-gray-100 hover:text-gray-900 focus:bg-gray-100 focus:text-gray-900"
                role="menuitem">Pies</a
              >
            </div>
          </details>
        </li>

        <li>
          <a
            href="/contact"
            class="px-2 py-1 rounded transition-colors duration-150
                   text-gray-700 hover:bg-gray-100 hover:text-gray-900
                   focus:bg-gray-100 focus:text-gray-900"
            >Contact</a
          >
        </li>
      </ul>
    </nav>
  </div>
</header>
