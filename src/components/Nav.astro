</ul>

      <!-- Mobile Button -->
      <button id="menu-btn" class="md:hidden z-50">
        <!-- Hamburger -->
        <svg id="icon-open" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>

        <!-- Close -->
        <svg id="icon-close" class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<div id="mobile-menu"
  class="fixed inset-0 bg-brand-cream z-40 hidden flex flex-col font-heading text-brand-dark-brown"
>
  <div class="flex flex-col h-full w-full pt-30 pb-8 px-8">
    
    <div id="menu-main" class="menu-panel flex-1 flex flex-col items-center justify-between">
      <div class="flex flex-col space-y-4 items-center text-center">
        <a href="/" class="mobile-link text-xl">Home</a>
        <a href="/about-us" class="mobile-link text-xl">About</a>
        <button class="menu-open text-xl" data-menu="products">Products</button>
        <button class="menu-open text-xl" data-menu="events">Events</button>
        <a href="/gallery" class="mobile-link text-xl">Gallery</a>
        <a href="/contact" class="mobile-link text-xl">Contact</a>
      </div>

      <button id="close" class="w-full max-w-xs py-4 bg-brand-teal text-white rounded-2xl font-bold uppercase tracking-widest shadow-md">
        Close Menu
      </button>
    </div>

    <div id="menu-products" class="menu-panel hidden flex-1 flex flex-col items-center justify-between">
      <div class="flex flex-col space-y-4 items-center text-center overflow-y-auto">
        <a href="/flavors" class="mobile-link text-xl">Cake Flavors</a>
        <a href="/pricing" class="mobile-link text-xl">Cake Pricing</a>
        <a href="/traditional-cookies" class="mobile-link text-xl">Traditional Cookies</a>
        <a href="/decorated-cookies" class="mobile-link text-xl">Decorated Cookies</a>
        <a href="/macarons" class="mobile-link text-xl">Macarons</a>
        <a href="/donuts" class="mobile-link text-xl">Donuts</a>
        <a href="/pies" class="mobile-link text-xl">Pies</a>
      </div>

      <button class="menu-back w-full max-w-xs py-4 bg-brand-teal text-white rounded-2xl font-bold uppercase shadow-md">
        ← Back
      </button>
    </div>

    <div id="menu-events" class="menu-panel hidden flex-1 flex flex-col items-center justify-between">
      <div class="flex flex-col space-y-6 items-center text-center">
        <a href="/weddings" class="mobile-link text-xl">Weddings</a>
        <a href="/parties" class="mobile-link text-xl">Parties</a>
      </div>

      <button class="menu-back w-full max-w-xs py-4 bg-brand-teal text-white rounded-2xl font-bold uppercase shadow-md">
        ← Back
      </button>
    </div>

  </div>
</div>

<script is:inline>
  const setupMenu = () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('menu-btn');
    const closebtn = document.getElementById('close'); 

    const openIcon = document.getElementById('icon-open');
    const closeIcon = document.getElementById('icon-close');

    const panels = document.querySelectorAll('.menu-panel');
    const openBtns = document.querySelectorAll('.menu-open');
    const backBtns = document.querySelectorAll('.menu-back');
    const links = document.querySelectorAll('.mobile-link');

    if (!menu || !btn) return;

    const showPanel = (id) => {
      panels.forEach(p => p.classList.add('hidden'));
      document.getElementById(`menu-${id}`).classList.remove('hidden');
    };

    const openMenu = () => {
      menu.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');

      openIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');

      showPanel('main');
    };

    const closeMenu = () => {
      menu.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');

      openIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    };

    const toggleMenu = () => {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    };

    // Open submenu
    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showPanel(btn.dataset.menu);
      });
    });

    // Back button
    backBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showPanel('main');
      });
    });

    // Close on link click
    //links.forEach(link => link.addEventListener('click', closeMenu)); I disabled this because when going to a new page, it was flickering.

    btn.addEventListener('click', toggleMenu);
    closebtn.addEventListener('click', closeMenu)
  };

  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>
