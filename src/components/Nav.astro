    </button>
    <ul class="absolute left-0 mt-2 w-48 bg-brand-light-cream border border-gray-100 shadow-lg rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-400 ">
      <li><a href="/weddings" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Weddings</a></li>
