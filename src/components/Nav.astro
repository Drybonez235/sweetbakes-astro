      <li><a href="/traditional-cookies" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Traditional Cookies</a></li>
      <li><a href="/decorated-cookies" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Decorated Cookies</a></li>
      <li><a href="/macarons" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Macarons</a></li>
      <li><a href="/donuts" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Donuts</a></li>
      <li><a href="/pies" class="block px-4 py-2 hover:bg-brand-cream hover:text-brand-terracotta">Pies</a></li>
