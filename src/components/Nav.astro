<div id="mobile-menu"
  class="fixed inset-0 bg-brand-cream z-40 hidden md:hidden flex flex-col justify-center text-2xl font-heading text-brand-dark-brown"
>

  <!-- MAIN MENU -->
  <div id="menu-main" class="menu-panel flex flex-col space-y-6 content-center items-center justify-center">
    <a href="/" class="mobile-link">HOME</a>
    <a href="/about-us" class="mobile-link">ABOUT</a>

    <div class="space-y-6 content-center items-center justify-center">
    <button class="menu-open block ml-11 " data-menu="products">PRODUCTS</button>
    <button class="menu-open block ml-11" data-menu="events">EVENTS</button>
    </div>

    <a href="/gallery" class="mobile-link ml-8">GALLERY</a>
    <a href="/contact" class="mobile-link ml-8">CONTACT</a>

    <div class="absolute bottom-24 w-3/4 h-8 px-4 bg-brand-teal rounded-2xl">
    <button id="close" class="w-full">Back</button>
      </div>
  </div>

  <!-- PRODUCTS -->
  <div id="menu-products" class="menu-panel hidden flex flex-col space-y-6 justify-center items-center mt-16">

    <a href="/flavors" class="mobile-link">Cake Flavors</a>
    <a href="/pricing" class="mobile-link">Cake Pricing</a>
    <a href="/traditional-cookies" class="mobile-link">Traditional Cookies</a>
    <a href="/decorated-cookies" class="mobile-link">Decorated Cookies</a>
    <a href="/macarons" class="mobile-link">Macarons</a>
    <a href="/donuts" class="mobile-link">Donuts</a>
    <a href="/pies" class="mobile-link">Pies</a>

    <div class="absolute bottom-24   bg-brand-teal rounded-2xl w-3/4 h-8 px-4">
    <button class="menu-back w-full">← Back</button>
    </div>
  </div>

  <!-- EVENTS -->
  <div id="menu-events" class="menu-panel hidden flex flex-col  space-y-6 justify-center items-center">
    <!-- <button class="menu-back">← Back</button> -->

    <a href="/weddings" class="mobile-link">Weddings</a>
    <a href="/parties" class="mobile-link">Parties</a>

    <div class="absolute bottom-24  bg-brand-teal rounded-2xl w-3/4 h-8 px-4">
    <button class="menu-back w-full">← Back</button>
    </div>
  </div>


</div>

<script is:inline>
  const setupMenu = () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('menu-btn');
    const closebtn = document.getElementById('close'); 

    const openIcon = document.getElementById('icon-open');
    const closeIcon = document.getElementById('icon-close');

    const panels = document.querySelectorAll('.menu-panel');
    const openBtns = document.querySelectorAll('.menu-open');
    const backBtns = document.querySelectorAll('.menu-back');
    const links = document.querySelectorAll('.mobile-link');

    if (!menu || !btn) return;

    const showPanel = (id) => {
      panels.forEach(p => p.classList.add('hidden'));
      document.getElementById(`menu-${id}`).classList.remove('hidden');
    };

    const openMenu = () => {
      menu.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');

      openIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');

      showPanel('main');
    };

    const closeMenu = () => {
      menu.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');

      openIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    };

    const toggleMenu = () => {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    };

    // Open submenu
    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showPanel(btn.dataset.menu);
      });
    });

    // Back button
    backBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showPanel('main');
      });
    });

    // Close on link click
    //links.forEach(link => link.addEventListener('click', closeMenu)); I disabled this because when going to a new page, it was flickering.

    btn.addEventListener('click', toggleMenu);
    closebtn.addEventListener('click', closeMenu)
  };

  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>
